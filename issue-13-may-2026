<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI Pulse – 13 May 2026</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Carlito:ital,wght@0,400;0,700;1,400;1,700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #08090A;
      --bg-soft: #0E1012;
      --bg-card: #14171A;
      --bg-elev: #181B1F;
      --text: #F4F6F7;
      --text-secondary: #B8BEC3;
      --text-muted: #7A8189;
      --text-dim: #4A5159;
      --accent: #5EEAD4;
      --accent-soft: rgba(94, 234, 212, 0.12);
      --accent-glow: rgba(94, 234, 212, 0.35);
      --accent-bright: #7DF0DD;
      --border: #1E2227;
      --border-strong: #2A2F36;
      --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
      --ease-out-quart: cubic-bezier(0.25, 1, 0.5, 1);
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg); color: var(--text);
      font-family: 'Carlito', 'Calibri', 'Segoe UI', sans-serif;
      font-weight: 400; line-height: 1.55;
      -webkit-font-smoothing: antialiased;
      min-height: 100vh; overflow-x: hidden;
      cursor: none;
    }
    @media (max-width: 720px) { body { cursor: auto; } }

    .container { max-width: 1280px; margin: 0 auto; padding: 0 40px; }

    /* === CUSTOM CURSOR === */
    .cursor-dot, .cursor-trail {
      position: fixed; pointer-events: none;
      border-radius: 50%; z-index: 9999;
      transform: translate(-50%, -50%);
      will-change: transform, left, top;
      mix-blend-mode: screen;
    }
    .cursor-dot {
      width: 8px; height: 8px;
      background: var(--accent);
      box-shadow: 0 0 12px var(--accent), 0 0 24px var(--accent-glow);
      transition: width 0.2s ease, height 0.2s ease, background 0.2s ease;
    }
    .cursor-dot.expanded {
      width: 40px; height: 40px;
      background: rgba(94, 234, 212, 0.2);
      box-shadow: 0 0 30px var(--accent-glow);
    }
    .cursor-trail {
      width: 36px; height: 36px;
      background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%);
      opacity: 0.6;
      transition: opacity 0.3s ease;
    }
    .cursor-trail.expanded { opacity: 0; }
    @media (max-width: 720px) {
      .cursor-dot, .cursor-trail { display: none; }
    }
    @media (prefers-reduced-motion: reduce) {
      .cursor-dot, .cursor-trail { display: none; }
      body { cursor: auto; }
    }

    /* === PROGRESS BAR === */
    .progress-bar {
      position: fixed; top: 0; left: 0;
      height: 2px; width: 0%;
      background: var(--accent); z-index: 1000;
      transition: width 0.1s linear;
      box-shadow: 0 0 12px var(--accent-glow);
    }

    /* === NAV === */
    nav {
      border-bottom: 1px solid var(--border);
      padding: 18px 0; position: sticky; top: 0;
      background: rgba(8, 9, 10, 0.85);
      backdrop-filter: blur(20px) saturate(180%);
      -webkit-backdrop-filter: blur(20px) saturate(180%);
      z-index: 100;
    }
    .nav-inner { display: flex; justify-content: space-between; align-items: center; gap: 24px; }
    .brand {
      display: flex; align-items: center; gap: 12px;
      font-weight: 700; font-size: 18px;
      color: var(--text); text-decoration: none;
      transition: color 0.3s ease;
    }
    .brand:hover { color: var(--accent); }
    .brand-mark {
      width: 28px; height: 28px;
      background: var(--accent);
      position: relative; flex-shrink: 0;
      transition: transform 0.5s var(--ease-out-expo), box-shadow 0.4s ease;
      box-shadow: 0 0 0 0 var(--accent-glow);
    }
    .brand:hover .brand-mark {
      transform: rotate(45deg);
      box-shadow: 0 0 24px var(--accent-glow);
    }
    .brand-mark::after {
      content: ''; position: absolute;
      top: 50%; left: 50%; transform: translate(-50%, -50%);
      width: 10px; height: 10px;
      background: var(--bg); border-radius: 50%;
    }
    .nav-meta { display: flex; align-items: center; gap: 16px; }
    .nav-date {
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px; letter-spacing: 0.08em;
      text-transform: uppercase; color: var(--accent);
      font-weight: 500;
    }
    .archive-link {
      font-family: 'Carlito', sans-serif; font-weight: 700;
      font-size: 13px;
      padding: 9px 20px;
      border: 1px solid var(--border-strong);
      border-radius: 100px;
      color: var(--text); text-decoration: none;
      transition: all 0.3s var(--ease-out-quart);
      display: inline-flex; align-items: center; gap: 8px;
      position: relative; overflow: hidden;
      background: transparent;
    }
    .archive-link::before {
      content: ''; position: absolute; inset: 0;
      background: var(--accent);
      transform: translateY(101%);
      transition: transform 0.4s var(--ease-out-quart);
    }
    .archive-link span, .archive-link svg { position: relative; z-index: 1; transition: color 0.3s ease; }
    .archive-link:hover {
      border-color: var(--accent);
      color: var(--bg);
      box-shadow: 0 0 24px var(--accent-glow);
    }
    .archive-link:hover::before { transform: translateY(0); }
    .archive-link svg {
      width: 12px; height: 12px;
      transition: transform 0.3s var(--ease-out-quart);
    }
    .archive-link:hover svg { transform: translateX(3px); }

    /* === HERO === */
    .hero {
      padding: 100px 0 80px;
      border-bottom: 1px solid var(--border);
      background: var(--bg);
      position: relative; overflow: hidden;
    }
    .hero-grid {
      position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(94, 234, 212, 0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(94, 234, 212, 0.04) 1px, transparent 1px);
      background-size: 48px 48px;
      mask-image: radial-gradient(ellipse at center, black 30%, transparent 80%);
      -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 80%);
      pointer-events: none;
    }
    .hero-glow {
      position: absolute; width: 700px; height: 700px;
      background: radial-gradient(circle, rgba(94, 234, 212, 0.15) 0%, transparent 60%);
      pointer-events: none;
      transform: translate(-50%, -50%);
      transition: left 0.8s var(--ease-out-expo), top 0.8s var(--ease-out-expo);
      left: 30%; top: 50%;
      filter: blur(20px);
    }
    .hero-inner {
      display: grid; grid-template-columns: 1fr 340px;
      gap: 80px; align-items: end;
      position: relative; z-index: 2;
    }
    .hero-eyebrow {
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px; letter-spacing: 0.18em;
      text-transform: uppercase; color: var(--accent);
      margin-bottom: 28px;
      display: flex; align-items: center; gap: 14px;
      animation: slideInLeft 0.8s var(--ease-out-expo) both;
    }
    .hero-eyebrow::before {
      content: ''; width: 32px; height: 1px;
      background: var(--accent);
      animation: lineGrow 1s var(--ease-out-expo) 0.2s both;
      transform-origin: left;
      box-shadow: 0 0 8px var(--accent-glow);
    }
    .live-dot {
      width: 6px; height: 6px;
      background: var(--accent); border-radius: 50%;
      box-shadow: 0 0 0 0 var(--accent-glow);
      animation: pulse 2s ease-in-out infinite;
    }
    .hero h1 {
      font-family: 'Carlito', sans-serif;
      font-weight: 700;
      font-size: clamp(40px, 5.4vw, 72px);
      line-height: 1.05; letter-spacing: -0.02em;
      color: var(--text); margin-bottom: 32px; max-width: 960px;
      animation: heroReveal 1.2s var(--ease-out-expo) 0.1s both;
    }
    .hero h1 em {
      font-style: italic; color: var(--accent);
      text-shadow: 0 0 30px var(--accent-glow);
    }
    .hero-sub {
      font-size: 17px; color: var(--text-secondary);
      max-width: 720px; line-height: 1.65;
      animation: heroReveal 1.2s var(--ease-out-expo) 0.3s both;
    }
    .hero-stats {
      display: flex; flex-direction: column;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-left: 3px solid var(--accent);
      animation: heroReveal 1.2s var(--ease-out-expo) 0.5s both;
      box-shadow: 0 0 40px rgba(94, 234, 212, 0.05);
    }
    .hero-stat {
      padding: 22px 28px;
      border-bottom: 1px solid var(--border);
      transition: background 0.3s var(--ease-out-quart);
    }
    .hero-stat:last-child { border-bottom: none; }
    .hero-stat:hover { background: var(--bg-elev); }
    .hero-stat-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px; letter-spacing: 0.14em;
      text-transform: uppercase; color: var(--text-muted);
      margin-bottom: 6px;
    }
    .hero-stat-value {
      font-family: 'Carlito', sans-serif; font-weight: 700;
      font-size: 26px; color: var(--text);
      letter-spacing: -0.02em; line-height: 1.1;
    }

    /* === FILTER === */
    .filter-band {
      padding: 22px 0; border-bottom: 1px solid var(--border);
      position: sticky; top: 65px;
      background: rgba(8, 9, 10, 0.85);
      backdrop-filter: blur(20px) saturate(180%);
      -webkit-backdrop-filter: blur(20px) saturate(180%);
      z-index: 90;
    }
    .filter-inner {
      display: flex; justify-content: space-between;
      align-items: center; gap: 20px; flex-wrap: wrap;
    }
    .filter-group { display: flex; align-items: center; gap: 18px; flex-wrap: wrap; }
    .filter-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px; letter-spacing: 0.16em;
      text-transform: uppercase; color: var(--text-muted);
    }
    .filter-chips { display: flex; gap: 6px; flex-wrap: wrap; }
    .chip {
      font-family: 'Carlito', sans-serif;
      font-size: 14px; font-weight: 700;
      padding: 9px 20px; border-radius: 100px;
      border: 1px solid var(--border-strong);
      background: transparent; color: var(--text-secondary);
      cursor: none;
      transition: all 0.3s var(--ease-out-quart);
    }
    .chip:hover {
      color: var(--accent); border-color: var(--accent);
      transform: translateY(-1px);
      box-shadow: 0 0 20px var(--accent-glow);
    }
    .chip.active {
      background: var(--accent); color: var(--bg);
      border-color: var(--accent);
      box-shadow: 0 0 30px var(--accent-glow);
    }
    .filter-count {
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px; color: var(--text-muted);
    }
    .filter-count strong {
      color: var(--accent); font-weight: 600;
      font-variant-numeric: tabular-nums;
    }

    /* === STORY NAV (right side dots) === */
    .story-nav {
      position: fixed; right: 28px; top: 50%;
      transform: translateY(-50%); z-index: 80;
      display: flex; flex-direction: column; gap: 14px;
      padding: 14px 8px;
    }
    .story-nav-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--border-strong);
      cursor: none; border: none; padding: 0;
      transition: all 0.4s var(--ease-out-expo);
      position: relative;
    }
    .story-nav-dot::before {
      content: attr(data-label); position: absolute;
      right: 16px; top: 50%;
      transform: translateY(-50%) translateX(8px);
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px; letter-spacing: 0.08em;
      text-transform: uppercase; color: var(--text);
      background: var(--bg-card);
      padding: 6px 12px;
      border: 1px solid var(--border-strong);
      border-radius: 4px;
      white-space: nowrap; opacity: 0; pointer-events: none;
      transition: all 0.3s var(--ease-out-quart);
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.4);
    }
    .story-nav-dot:hover { background: var(--accent); transform: scale(1.4); box-shadow: 0 0 12px var(--accent-glow); }
    .story-nav-dot:hover::before { opacity: 1; transform: translateY(-50%) translateX(0); }
    .story-nav-dot.active {
      background: var(--accent); width: 24px;
      border-radius: 4px;
      box-shadow: 0 0 0 4px var(--accent-soft), 0 0 16px var(--accent-glow);
    }

    /* === STORIES === */
    .stories { padding: 80px 0 32px; }
    .story {
      padding: 64px 0; border-bottom: 1px solid var(--border);
      opacity: 0; transform: translateY(40px);
      transition: opacity 1s var(--ease-out-expo), transform 1s var(--ease-out-expo);
    }
    .story.in-view { opacity: 1; transform: translateY(0); }
    .story.filter-hidden {
      opacity: 0; transform: scale(0.96) translateY(20px);
      pointer-events: none; max-height: 0;
      overflow: hidden; padding: 0; border: none;
      transition: all 0.5s var(--ease-out-expo);
    }
    .story-header {
      display: grid; grid-template-columns: 100px 1fr;
      gap: 40px; margin-bottom: 32px; align-items: start;
    }
    .story-num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px; color: var(--text-muted);
      letter-spacing: 0.12em; padding-top: 12px;
      font-weight: 500;
      position: sticky; top: 140px;
    }
    .story-num .num-current { color: var(--accent); }
    .story-meta { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 24px; }
    .tag {
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px; letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 5px 12px; border-radius: 2px;
      border: 1px solid currentColor; font-weight: 500;
      transition: all 0.3s ease;
      color: var(--text-muted);
    }
    .tag:hover { transform: translateY(-2px); color: var(--accent); box-shadow: 0 0 12px var(--accent-glow); }

    .story h2 {
      font-family: 'Carlito', sans-serif; font-weight: 700;
      font-size: clamp(26px, 3vw, 38px);
      line-height: 1.18; letter-spacing: -0.015em;
      color: var(--text); margin-bottom: 28px; max-width: 940px;
      transition: color 0.3s ease;
    }
    .story:hover h2 { color: var(--accent-bright); }

    .plain-text { max-width: 880px; margin-bottom: 28px; }
    .plain-text p {
      font-size: 17px; line-height: 1.75;
      color: var(--text-secondary); margin-bottom: 14px;
    }
    .plain-text p:last-child { margin-bottom: 0; }

    .why-matters {
      max-width: 880px; padding: 24px 28px;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-left: 3px solid var(--accent);
      margin-bottom: 44px;
      font-size: 15px; line-height: 1.7;
      color: var(--text);
      transition: all 0.4s var(--ease-out-quart);
      position: relative; overflow: hidden;
    }
    .why-matters::after {
      content: ''; position: absolute;
      inset: 0;
      background: linear-gradient(120deg, transparent 30%, var(--accent-soft) 50%, transparent 70%);
      transform: translateX(-100%);
      transition: transform 0.8s var(--ease-out-quart);
      pointer-events: none;
    }
    .why-matters:hover {
      transform: translateX(2px);
      border-color: var(--accent);
      box-shadow: 0 0 24px rgba(94, 234, 212, 0.08);
    }
    .why-matters:hover::after { transform: translateX(100%); }
    .why-matters strong {
      color: var(--accent); font-weight: 700;
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px; text-transform: uppercase;
      letter-spacing: 0.14em;
      display: inline-block; margin-right: 10px;
      vertical-align: 2px;
    }

    .section-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px; letter-spacing: 0.18em;
      text-transform: uppercase; color: var(--text);
      font-weight: 600;
      margin-bottom: 22px; padding-bottom: 14px;
      border-bottom: 1px solid var(--border);
      max-width: 920px;
      display: flex; align-items: center; gap: 12px;
    }
    .section-label::before {
      content: ''; width: 6px; height: 6px;
      background: var(--accent); border-radius: 50%;
      box-shadow: 0 0 8px var(--accent-glow);
    }

    /* === KEY METRIC CARDS - 3D PARALLAX === */
    .indicators-block { margin-bottom: 44px; }
    .indicators {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 14px;
      max-width: 920px;
      perspective: 1200px;
    }
    .indicator {
      background: var(--bg-card);
      padding: 24px 26px;
      display: flex; flex-direction: column; gap: 10px;
      border: 1px solid var(--border);
      transform-style: preserve-3d;
      transition: transform 0.15s ease-out, border-color 0.3s ease, box-shadow 0.3s ease;
      position: relative; overflow: hidden;
      cursor: none;
    }
    .indicator::before {
      content: ''; position: absolute;
      top: 0; left: 0;
      width: 100%; height: 100%;
      background: radial-gradient(circle at var(--mouse-x, 50%) var(--mouse-y, 50%), var(--accent-soft) 0%, transparent 50%);
      opacity: 0;
      transition: opacity 0.3s ease;
      pointer-events: none;
    }
    .indicator::after {
      content: ''; position: absolute;
      bottom: 0; left: 0;
      width: 0; height: 2px;
      background: var(--accent);
      transition: width 0.6s var(--ease-out-expo);
      box-shadow: 0 0 8px var(--accent-glow);
    }
    .indicator:hover {
      border-color: var(--accent);
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5), 0 0 30px rgba(94, 234, 212, 0.1);
    }
    .indicator:hover::before { opacity: 1; }
    .indicator:hover::after { width: 100%; }
    .indicator-value {
      font-family: 'Carlito', sans-serif; font-weight: 700;
      font-size: 30px; color: var(--text);
      letter-spacing: -0.025em; line-height: 1.1;
      font-variant-numeric: tabular-nums;
      transform: translateZ(20px);
      transition: color 0.3s ease;
    }
    .indicator:hover .indicator-value {
      color: var(--accent);
      text-shadow: 0 0 20px var(--accent-glow);
    }
    .indicator-value.mono {
      font-family: 'JetBrains Mono', monospace;
      font-size: 20px; font-weight: 600;
    }
    .indicator-desc {
      font-size: 13px; line-height: 1.55;
      color: var(--text-muted);
      transform: translateZ(10px);
    }
    .indicator:hover .indicator-desc { color: var(--text-secondary); }

    /* === IMPACT CARDS === */
    .impact-block { margin-bottom: 44px; }
    .impact-card {
      max-width: 920px; padding: 26px 30px;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-left: 3px solid var(--text-dim);
      margin-bottom: 12px;
      transition: all 0.4s var(--ease-out-quart);
    }
    .impact-card:hover {
      transform: translateX(6px);
      border-color: var(--border-strong);
      border-left-color: var(--accent);
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.4);
    }
    .impact-audience {
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px; letter-spacing: 0.1em;
      text-transform: uppercase; font-weight: 600;
      margin-bottom: 14px; color: var(--accent);
      display: flex; align-items: center; gap: 10px;
    }
    .impact-audience::before {
      content: '→'; font-size: 13px;
      transition: transform 0.3s var(--ease-out-quart);
      color: var(--accent);
    }
    .impact-card:hover .impact-audience::before { transform: translateX(4px); }
    .impact-card p {
      font-size: 15px; line-height: 1.75;
      color: var(--text-secondary); margin-bottom: 10px;
    }
    .impact-card p:last-child { margin-bottom: 0; }

    /* === SOURCE === */
    .source-block {
      max-width: 920px; padding-top: 24px;
      border-top: 1px solid var(--border);
      display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
    }
    .source-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px; letter-spacing: 0.18em;
      text-transform: uppercase; color: var(--text-muted);
      font-weight: 500;
    }
    .source-block a {
      color: var(--text); text-decoration: none;
      font-size: 14px; position: relative; padding-bottom: 2px;
      transition: color 0.3s ease;
    }
    .source-block a::after {
      content: ''; position: absolute;
      left: 0; bottom: 0;
      width: 100%; height: 1px;
      background: var(--accent);
      transform-origin: right; transform: scaleX(0.3);
      transition: transform 0.4s var(--ease-out-quart);
      box-shadow: 0 0 6px var(--accent-glow);
    }
    .source-block a:hover { color: var(--accent); }
    .source-block a:hover::after { transform-origin: left; transform: scaleX(1); }
    .source-meta { font-size: 13px; color: var(--text-muted); }

    /* === EDITORIAL === */
    .editorial {
      padding: 120px 0;
      background: var(--bg-soft);
      border-bottom: 1px solid var(--border);
      position: relative; overflow: hidden;
    }
    .editorial::before {
      content: '"'; position: absolute;
      top: 30px; left: 5%;
      font-family: 'Carlito', serif; font-style: italic;
      font-size: 360px; line-height: 1; font-weight: 700;
      color: var(--accent);
      opacity: 0.06; pointer-events: none;
    }
    .editorial-inner { max-width: 920px; margin: 0 auto; position: relative; z-index: 2; }
    .editorial-eyebrow {
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px; letter-spacing: 0.18em;
      text-transform: uppercase; color: var(--accent);
      margin-bottom: 40px; font-weight: 600;
      display: flex; align-items: center; gap: 12px;
    }
    .editorial-eyebrow::before {
      content: ''; width: 32px; height: 1px;
      background: var(--accent);
      box-shadow: 0 0 8px var(--accent-glow);
    }
    .editorial blockquote {
      font-family: 'Carlito', sans-serif; font-weight: 700;
